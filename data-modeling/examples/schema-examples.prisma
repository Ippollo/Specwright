// This is a sample Prisma Schema demonstrating Data Modeling Best Practices
// It is NOT meant to be run directly, but to serve as a reference.

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// -----------------------------------------------------------------------------
// 1. Naming Conventions & Core Design
// -----------------------------------------------------------------------------

model User {
  // Use UUIDs for IDs
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  role      UserRole @default(USER) // Use Enums
  
  // Standard timestamps
  createdAt DateTime @default(now()) @map("created_at") // Map camelCase to snake_case db columns
  updatedAt DateTime @updatedAt @map("updated_at")

  // Soft Delete Field
  deletedAt DateTime? @map("deleted_at")

  // 1:1 Relation
  profile   Profile?

  // 1:N Relation
  posts     Post[]

  // M:N Relation (Implicit syntax often preferred, but Explicit shown in 'Article' below for clarity)
  groups    Group[] 
  
  @@map("users") // Table names plural snake_case
  
  // Partial index for soft delete uniqueness
  // (Prisma syntax varies for raw indexes, often handled in manual migration SQL)
}

// Enum Definition
enum UserRole {
  USER
  ADMIN
  MANAGER
}

// -----------------------------------------------------------------------------
// 2. Relationship Patterns
// -----------------------------------------------------------------------------

model Profile {
  id     String  @id @default(uuid())
  bio    String?
  userId String  @unique @map("user_id") // Unique constraint makes this 1:1
  user   User    @relation(fields: [userId], references: [id])
  
  @@map("profiles")
}

model Post {
  id        String   @id @default(uuid())
  title     String
  content   String
  published Boolean  @default(false)
  authorId  String   @map("author_id")
  author    User     @relation(fields: [authorId], references: [id])
  
  // Polymorphic-style comments (Prisma doesn't native support polymorphic, 
  // so we often use explicit relations or a JSON field if simple)
  comments  Comment[]

  @@map("posts")
  @@index([authorId]) // Always index Foreign Keys
}

model Group {
  id    String @id @default(uuid())
  name  String
  users User[] // Implicit M:N
  @@map("groups")
}

// -----------------------------------------------------------------------------
// 3. Advanced M:N (Explicit Junction Table)
// -----------------------------------------------------------------------------

model Tag {
  id       String       @id @default(uuid())
  name     String
  articles ArticleTax[]

  @@map("tags")
}

model Article {
  id    String       @id @default(uuid())
  title String
  tags  ArticleTax[]

  @@map("articles")
}

// Junction Table
model ArticleTax {
  articleId String  @map("article_id")
  article   Article @relation(fields: [articleId], references: [id])
  tagId     String  @map("tag_id")
  tag       Tag     @relation(fields: [tagId], references: [id])

  assignedAt DateTime @default(now())
  assignedBy String?

  @@id([articleId, tagId]) // Composite Primary Key
  @@map("article_tags")
}

// -----------------------------------------------------------------------------
// 4. Comment (Polymorphic-ish implementation via Exclusive FKs)
// -----------------------------------------------------------------------------
// Since standard SQL polymorphism loses FK integrity, this pattern is often
// safer in Prisma if you have a finite set of parents.

model Comment {
  id      String @id @default(uuid())
  content String

  // Parent 1: Post
  postId String? @map("post_id")
  post   Post?   @relation(fields: [postId], references: [id])

  // Parent 2: Article
  articleId String?  @map("article_id") 
  // article Article? ... (Relation definition would go here)

  createdAt DateTime @default(now())
  @@map("comments")
}

// -----------------------------------------------------------------------------
// 5. Audit Log (Generic)
// -----------------------------------------------------------------------------

model AuditLog {
  id         String   @id @default(uuid())
  tableName  String   @map("table_name")
  recordId   String   @map("record_id")
  action     String   // INSERT, UPDATE, DELETE
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  changedBy  String?  @map("changed_by")
  changedAt  DateTime @default(now()) @map("changed_at")

  @@index([tableName, recordId])
  @@map("audit_logs")
}
